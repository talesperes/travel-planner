# Porta HTTP do backend.
PORT=3001

# Origens permitidas para CORS (lista separada por vírgula).
# Em produção é obrigatório; em desenvolvimento o default é http://localhost:5173.
FRONTEND_ORIGIN=http://localhost:5173

# Credenciais do projeto Supabase (Project Settings → API).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
